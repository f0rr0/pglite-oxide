index dcd1ea8..21d27b3 100644
--- a/src/backend/utils/error/elog.c
+++ b/src/backend/utils/error/elog.c
@@ -1744,6 +1744,30 @@ EmitErrorReport(void)
 	recursion_depth--;
 }

+#ifdef PGLITE_WASIX_DL
+/*
+ * PGlite's WASIX host can receive PostgreSQL ERROR unwinds as a Wasmer trap
+ * before the embedded protocol loop resumes at its sigsetjmp boundary.  The
+ * explicit host recovery export calls back while ErrorData is still live, so
+ * preserve PostgreSQL's own fields and frontend formatter while recomputing the
+ * client-output decision at that boundary.
+ */
+void
+pglite_emit_error_report_to_frontend(void)
+{
+	ErrorData  *edata;
+
+	if (errordata_stack_depth < 0)
+		return;
+
+	edata = &errordata[errordata_stack_depth];
+	if (edata->elevel < ERROR)
