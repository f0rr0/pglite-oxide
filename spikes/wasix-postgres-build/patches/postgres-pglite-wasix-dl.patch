+	dup2(saved_stdin, STDIN_FILENO);
+	close(saved_stdin);
+	clearerr(stdin);
+}
+
+static bool
+pglite_run_initdb_boot_phase(void) {
+	PDEBUG("# 450: restarting in boot mode for initdb");
+	int saved_stdin = dup(STDIN_FILENO);
+	if (saved_stdin < 0) {
+		fprintf(stderr, "could not save stdin before initdb boot phase: %s\n", strerror(errno));
+		return false;
+	}
+	if (freopen(IDB_PIPE_BOOT, "r", stdin) == NULL) {
+		fprintf(stderr, "could not open initdb boot pipe \"%s\": %s\n", IDB_PIPE_BOOT, strerror(errno));
+		pglite_restore_stdin_after_initdb_boot(saved_stdin);
+		return false;
+	}
